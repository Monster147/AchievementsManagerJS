{{#if searchedGames}}
  <h3>Resultados da Pesquisa:</h3>
  <div class="games-grid">
    {{#each searchedGames}}
      <div class="game-card">
        <img 
          src="{{this.cover}}" 
          alt="Capa de {{this.name}}" 
        />
        <div class="game-card-title">{{this.name}}</div>

        <form action="/site/games" method="POST" class="mt-2">
          <input type="hidden" name="name" value="{{this.name}}">
          <input type="hidden" name="cover" value="{{this.cover}}">
          <button type="submit" class="btn btn-success">Adicionar à Lista</button>
        </form>
      </div>
    {{/each}}
  </div>

  <style>
    .games-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }

    .game-card {
      border: 1px solid #ccc;
      border-radius: 10px;
      overflow: hidden;
      text-align: center;
      background-color: #121212;
      padding: 10px;
      transition: 0.2s ease-in-out;
    }

    .game-card:hover {
      transform: scale(1.05);
    }

    .game-card img {
      width: 100%;
      height: auto;
      border-bottom: 1px solid #ccc;
    }

    .game-card-title {
      padding: 10px 0;
      font-weight: bold;
    }
  </style>
  
{{else}}
  <p class="no-results-text">Nenhum jogo foi encontrado.</p>
  <style>
    .no-results-text {
      color: #ccc;
      text-align: center;
      margin-top: 20px;
      font-style: italic;
    }
</style>
{{/if}}