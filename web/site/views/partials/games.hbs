<section class="container p-2">
  <h2 class="text-center mb-4 text-white">Lista de Jogos</h2>

  <div class="text-center mb-4">
    <a href="/site/games/custom" class="btn btn-success">Criar Jogo Personalizado</a>
  </div>

  <!-- Global Progress -->
  <div class="mb-4">
    <h5 class="mb-2 text-white text-center">
      Progresso Global: {{unlockedAchievements}} / {{totalAchievements}} conquistas
    </h5>
    <div class="progress" style="height: 25px; position: relative;">
      <div 
        class="progress-bar bg-success" 
        role="progressbar" 
        style="width: {{globalPercent}}%;" 
        aria-valuenow="{{globalPercent}}" 
        aria-valuemin="0" 
        aria-valuemax="100">
      </div>
      <span 
      class="position-absolute top-50 start-50 translate-middle fw-bold"
      style="color: {{#if (lt globalPercent 50)}}black{{else}}white{{/if}};">
      {{globalPercent}}%
    </span>
    </div>
  </div>

  <!-- Contadores de Jogos -->
  <div class="mb-4 text-white text-center">
    <h5>Total de Jogos: {{totalGames}}</h5>
    <h5>Jogos com Conquistas: {{totalGamesWithAchievements}}</h5>
  </div>

  {{#groupByPlatform games}}
  <div class="platform-section mt-5">
    <div class="platform-title">
      <h3>{{platform}} Games</h3>
      <div class="platform-line"></div>
    </div>
    <div class="games-grid">
      {{#each games}}
        <div class="game-card {{#if this.isCompleted}}game-completed{{else}}game-not-completed{{/if}}">
          <img src="{{this.cover}}" alt="Capa de {{this.name}}">
          <div class="game-card-body">
            <div class="game-card-title">{{this.name}}</div>
              <a href="/site/games/{{this.id}}" class="btn btn-danger">Ver Detalhes</a>
            </div>
          </div>
      {{/each}}
    </div>
  </div>
  {{/groupByPlatform}}

  <style>
    body {
      background-color: #121212;
      color: #f1f1f1;
    }

    .games-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }

    .game-card {
      background-color: #1e1e1e;
      border: 1px solid #333;
      border-radius: 12px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
      transition: transform 0.2s ease-in-out, box-shadow 0.3s ease, border-color 0.25s ease;
    }

    .game-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 16px rgba(255, 255, 255, 0.1);
    }

    .game-card img {
      width: 100%;
      height: 240px;
      object-fit: contain;
      background-color: #121212;
      border-bottom: 1px solid #444;
    }

    .game-card-body {
      padding: 15px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .game-card-title {
      font-weight: 600;
      margin-bottom: 10px;
      color: #fff;
      text-align: center;
    }

    .game-completed:hover {
      border-color: #2ecc71;
      box-shadow: 0 0 14px rgba(46, 204, 113, 0.45);
    }

    /* Not completed → red on hover */
    .game-not-completed:hover {
      border-color: #e74c3c;
      box-shadow: 0 0 14px rgba(231, 76, 60, 0.4);
    }

    .platform-title {
      text-align: center;
      margin-bottom: 20px;
      position: relative;
    }

    .platform-title h3 {
      color: #fff;
      margin: 0;
      display: inline-block;
      padding-bottom: 5px;
      font-size: 1.8rem;
    }

    .platform-line {
      width: 80px;
      height: 2px;
      background-color: #777;
      margin: 8px auto 0 auto;
      border-radius: 1px;
    }


    .btn-danger {
      background-color: #c1121f;
      border: none;
      transition: background-color 0.2s;
    }

    .btn-danger:hover {
      background-color: #a30e1a;
    }


  </style>
</section>